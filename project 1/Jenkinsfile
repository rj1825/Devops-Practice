pipeline {
    agent any

    environment {
        DOCKER_REGISTRY = 'myregistry.local:5000'
        BACKEND_IMAGE   = 'kanban-backend'
        FRONTEND_IMAGE  = 'kanban-frontend'
        IMAGE_TAG       = "${BUILD_NUMBER}"
        KUBECONFIG_CREDENTIAL_ID = 'kubeconfig-credentials'
    }

    stages {
        stage('Initialize & Lint') {
            steps {
                echo 'Checking and linting codebase...'
                dir('project 1/backend') {
                    sh 'python3 -m pip install -r requirements.txt --user --break-system-packages'
                    sh 'python3 -m compileall .'
                }
                dir('project 1/frontend') {
                    echo 'Linting static HTML/CSS/JS frontend files...'
                    // Place validation commands here if ESLint or similar tools are configured
                }
            }
        }

        stage('Backend Unit Tests') {
            steps {
                echo 'Running unit tests for backend API service...'
                dir('project 1/backend') {
                    // Run pytest
                    sh 'python3 -m pytest'
                }
            }
        }

        stage('Docker Build') {
            steps {
                echo 'Building backend and frontend Docker images...'
                
                dir('project 1/backend') {
                    sh "docker build -t ${DOCKER_REGISTRY}/${BACKEND_IMAGE}:${IMAGE_TAG} ."
                    sh "docker tag ${DOCKER_REGISTRY}/${BACKEND_IMAGE}:${IMAGE_TAG} ${DOCKER_REGISTRY}/${BACKEND_IMAGE}:latest"
                }
                
                dir('project 1/frontend') {
                    sh "docker build -t ${DOCKER_REGISTRY}/${FRONTEND_IMAGE}:${IMAGE_TAG} ."
                    sh "docker tag ${DOCKER_REGISTRY}/${FRONTEND_IMAGE}:${IMAGE_TAG} ${DOCKER_REGISTRY}/${FRONTEND_IMAGE}:latest"
                }
            }
        }

        stage('Security Scan') {
            steps {
                echo 'Scanning container images with Trivy (simulated)...'
                // trivy image --exit-code 0 --severity HIGH,CRITICAL ${DOCKER_REGISTRY}/${BACKEND_IMAGE}:${IMAGE_TAG}
                // trivy image --exit-code 0 --severity HIGH,CRITICAL ${DOCKER_REGISTRY}/${FRONTEND_IMAGE}:${IMAGE_TAG}
            }
        }

        stage('Push Docker Images') {
            steps {
                echo 'Pushing Docker images to local registry (simulated)...'
                echo "docker push ${DOCKER_REGISTRY}/${BACKEND_IMAGE}:${IMAGE_TAG}"
                echo "docker push ${DOCKER_REGISTRY}/${FRONTEND_IMAGE}:${IMAGE_TAG}"
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                echo 'Applying Kubernetes manifests to the cluster (simulated)...'
                dir('project 1') {
                    // Simulating deployment commands
                    echo 'kubectl apply -f k8s/configmap.yaml'
                    echo 'kubectl apply -f k8s/redis-deployment.yaml'
                    echo 'kubectl apply -f k8s/backend-deployment.yaml'
                    echo 'kubectl apply -f k8s/frontend-deployment.yaml'
                    echo "kubectl set image deployment/backend-deployment backend=${DOCKER_REGISTRY}/${BACKEND_IMAGE}:${IMAGE_TAG}"
                    echo "kubectl set image deployment/frontend-deployment frontend=${DOCKER_REGISTRY}/${FRONTEND_IMAGE}:${IMAGE_TAG}"
                }
            }
        }
    }

    post {
        success {
            echo "CI/CD Deployment successful for Build #${BUILD_NUMBER}!"
        }
        failure {
            echo "CI/CD Pipeline failed. Please check build logs."
        }
    }
}
